{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CredentialsApi3",
  "title": "CredentialsApi3",
  "type": "object",
  "description": "API3 client credentials for a user",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64",
      "description": "Unique identifier",
      "readOnly": true,
      "example": "abc123"
    },
    "client_id": {
      "type": "string",
      "description": "API3 client ID",
      "example": "500123"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when these credentials were created",
      "example": "2026-01-15T10:30:00Z"
    },
    "is_disabled": {
      "type": "boolean",
      "description": "Whether these credentials are disabled",
      "example": true
    },
    "type": {
      "type": "string",
      "description": "Credential type",
      "example": "example_value"
    },
    "url": {
      "type": "string",
      "description": "Relative URL",
      "readOnly": true,
      "example": "https://www.example.com"
    }
  }
}