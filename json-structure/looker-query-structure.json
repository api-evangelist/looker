{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Query",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "model": {
      "type": "string"
    },
    "view": {
      "type": "string"
    },
    "fields": {
      "type": "array"
    },
    "pivots": {
      "type": "array"
    },
    "fill_fields": {
      "type": "array"
    },
    "filters": {
